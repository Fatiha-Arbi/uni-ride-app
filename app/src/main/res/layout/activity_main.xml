<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offer a New Ride 🚗"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:textColor="#333333"/>

        <EditText
            android:id="@+id/etPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pickup Location Name"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPickPickup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Select Pickup on Map"
            android:backgroundTint="#6C757D"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etDestination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Destination Name"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPickDest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏁 Select Destination on Map"
            android:backgroundTint="#6C757D"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etFare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fare (৳)"
            android:inputType="numberDecimal"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etSeats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Available Seats"
            android:inputType="number"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your Phone Number"
            android:inputType="phone"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnCreateRide"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Create Ride"
            android:textSize="18sp"
            android:backgroundTint="#0066CC"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnViewRides"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Available Rides"
            android:backgroundTint="#F8F9FA"
            android:textColor="#333333"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>

    </LinearLayout>
</ScrollView>